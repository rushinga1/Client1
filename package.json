{
  "name": "agruni-waste-management",
  "version": "1.0.0",
  "description": "Agruni Waste Management User Portal - Vue 3 + TypeScript + Vite",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "vue-i18n": "^9.13.1",
    "@iconify/vue": "^4.1.1",
    "@vueuse/motion": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/tsconfig": "^0.5.1",
    "typescript": "~5.4.0",
    "vue-tsc": "^2.0.6",
    "vite": "^5.2.8",
    "eslint": "^9.0.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint-plugin-vue": "^9.28.0",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.38",
    "@types/node": "^20.11.30"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "typescript",
    "vite",
    "waste-management",
    "agruni",
    "rwanda"
  ],
  "author": "Agruni Team",
  "license": "MIT"
}
